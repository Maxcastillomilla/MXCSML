---
// ─────────────────────────────────────────────────────────────────────────────
// BASE LAYOUT
// El "esqueleto" HTML que envuelve TODAS las páginas del sitio.
// Incluye: <head> con fuentes y SEO, Navbar, Footer, y el <slot /> donde
// cada página inyecta su contenido.
//
// LOADER:
//   Al cargar la página por primera vez aparece una cortina fucsia (#ea027e)
//   con "MXCSML" en grande y efecto glitch/scramble mientras los recursos
//   se están descargando. Desaparece con fade cuando window.load dispara.
//   Solo se muestra en carga inicial — no en navegaciones View Transition.
//
// Para usarlo en una página nueva:
//   import BaseLayout from '../layouts/BaseLayout.astro';
//   <BaseLayout title="Mi página">...contenido...</BaseLayout>
// ─────────────────────────────────────────────────────────────────────────────
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Computational design researcher and architect.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  <meta name="description" content={description} />

  <ClientRouter />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ── LOADER ─────────────────────────────────────────────────────────────────
       Cortina de carga: cubre toda la pantalla con fondo fucsia mientras los
       recursos se descargan. Se elimina del DOM cuando window.load dispara.

       Desktop: "MXCSML" horizontal centrado
       Mobile:  "MXCSML" rotado 90° (texto vertical) para llenar la pantalla
  ─────────────────────────────────────────────────────────────────────────────── -->
  <div id="page-loader" aria-hidden="true">
    <span id="loader-text">MXCSML</span>
    <!-- Barra de progreso: animación CSS fija de ~4s — indicador visual de carga -->
    <div id="loader-bar"></div>
  </div>

  <style>
    /* Cortina: cubre todo, z-index máximo */
    #page-loader {
      position: fixed;
      inset: 0;
      z-index: 999999;
      background: #ea027e;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.7s ease;
    }

    /* Clase que se agrega al salir — fade out */
    #page-loader.loader-exit {
      opacity: 0;
      pointer-events: none;
    }

    /* Texto principal — desktop horizontal */
    #loader-text {
      font-family: 'Syne', 'Arial Black', sans-serif;
      font-weight: 800;
      font-size: clamp(5rem, 16vw, 18rem);
      color: #ffffff;
      letter-spacing: -0.03em;
      line-height: 1;
      user-select: none;
    }

    /* Mobile: texto vertical rotado para llenar la pantalla en portrait */
    @media (max-width: 767px) {
      #loader-text {
        writing-mode: vertical-rl;
        transform: rotate(180deg);
        font-size: clamp(4rem, 22vw, 7rem);
        letter-spacing: -0.02em;
      }
    }

    /* Barra de progreso: línea blanca semitransparente en la parte inferior */
    #loader-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      width: 0%;
      background: rgba(255, 255, 255, 0.5);
      animation: loader-progress 3.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    @keyframes loader-progress {
      0%   { width: 0%; }
      60%  { width: 75%; }
      90%  { width: 92%; }
      100% { width: 100%; }
    }
  </style>

  <script>
    // ── Loader: scramble mientras carga, sale al disparar window.load ──────────
    // Solo se muestra en la carga inicial de la página (no en View Transitions).
    // El efecto scramble reemplaza los chars de "MXCSML" con caracteres random
    // a 60fps para transmitir que algo está pasando.

    const ORIGINAL   = 'MXCSML';
    const GLITCH_SET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ█▓▒░▄▀■';
    let   rafId: number;
    let   exited      = false;
    let   pageLoaded  = false;  // window.load disparó
    let   textureReady = false; // textura de Three.js lista (o página sin hero)

    function randChar(): string {
      return GLITCH_SET[Math.floor(Math.random() * GLITCH_SET.length)];
    }

    function scrambleLoop() {
      const el = document.getElementById('loader-text');
      if (!el) return;
      el.textContent = [...ORIGINAL].map(() => randChar()).join('');
      rafId = requestAnimationFrame(scrambleLoop);
    }

    function exitLoader() {
      if (exited) return;
      exited = true;
      cancelAnimationFrame(rafId);

      const text   = document.getElementById('loader-text');
      const loader = document.getElementById('page-loader');
      if (!text || !loader) return;

      text.textContent = ORIGINAL;
      // Forzar scroll al top antes de revelar la página
      window.scrollTo({ top: 0, behavior: 'instant' });
      setTimeout(() => {
        loader.classList.add('loader-exit');
        setTimeout(() => loader.remove(), 750);
      }, 350);
    }

    // Solo salir cuando AMBAS condiciones estén listas
    function checkReady() {
      if (pageLoaded && textureReady) exitLoader();
    }

    scrambleLoop();

    // Condición 1: página HTML + recursos estáticos cargados
    window.addEventListener('load', () => {
      pageLoaded = true;
      // Si esta página no tiene canvas de Three.js (ej: página de proyecto),
      // la textura no va a disparar — se marca como lista directamente
      if (!document.getElementById('hero-canvas')) {
        textureReady = true;
      }
      checkReady();
    });

    // Condición 2: textura de perfil.png lista en Three.js
    window.addEventListener('hero-texture-loaded', () => {
      textureReady = true;
      checkReady();
    });

    // Seguridad: salir máximo a los 8 segundos aunque algo falle
    setTimeout(exitLoader, 8000);
  </script>

  <Navbar />
  <main>
    <slot />
  </main>
  <Footer />

  <script>
    // Fix para navegación con hash (ej: /#projects).
    // Cuando Astro hace una transición de página, el scroll se pierde.
    // Este script lo restaura automáticamente después del swap.
    document.addEventListener('astro:after-swap', () => {
      const hash = location.hash;
      if (hash) {
        const el = document.querySelector(hash);
        el?.scrollIntoView({ behavior: 'instant' });
      }
    });

    // Fix del loader en View Transitions:
    // Cuando se navega entre páginas, Astro inyecta el HTML de la página nueva
    // (que incluye el #page-loader del layout) antes del swap. El script del
    // loader NO corre de nuevo (módulos deduplicados), así que el loader
    // quedaría visible y sin forma de cerrarse.
    // Solución: eliminarlo del documento entrante ANTES de que se haga el swap.
    document.addEventListener('astro:before-swap', (e) => {
      const incoming = (e as CustomEvent & { newDocument: Document }).newDocument;
      incoming?.getElementById('page-loader')?.remove();
    });
  </script>

</body>
</html>
