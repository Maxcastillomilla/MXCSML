---
// ─────────────────────────────────────────────────────────────────────────────
// PROJECT GRID
// Grilla plana de 5 columnas con celda vacía decorativa por grupo.
//
// LAYOUT (desktop):
//   - Grid de 5 columnas, sin divs de fila intermedios (grid plano)
//   - Cada grupo de 3 proyectos: 1 WIDE (span 2) + 2 NARROW (span 1) + 1 VACÍA (span 1)
//     → 2+1+1+1 = 5 cols por grupo, posiciones mezcladas al azar en cada build
//   - La celda vacía solo existe en desktop — en mobile se oculta via CSS
//
// FILTRADO:
//   - Al activar un filtro de tag, las celdas vacías se ocultan para que
//     los proyectos restantes se reagrupen sin huecos
//   - tag-filter.ts gestiona la visibilidad usando data-group para saber
//     qué celda vacía corresponde a cada grupo de tarjetas
//
// SHOW MORE:
//   - Por defecto se muestran INITIAL_VISIBLE proyectos (≈2 filas)
//   - La celda vacía de un grupo completamente plegado también se oculta
//   - El botón "Ver más" revela el resto y puede volver a contraerse
//
// MOBILE (< 768px):
//   - 1 columna, celdas vacías ocultas, wide se voltea a vertical
// ─────────────────────────────────────────────────────────────────────────────
import ProjectCard from './ProjectCard.astro';
import TagFilter from './TagFilter.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
  allTags: string[];
}

const { projects, allTags } = Astro.props;
const BORDER = '1px solid #c2c2c2';
const INITIAL_VISIBLE = 6; // 2 grupos de 3 proyectos visibles por defecto

// Construir lista plana de slots mezclando posiciones dentro de cada grupo
type Slot =
  | { type: 'card'; project: CollectionEntry<'projects'>; projectIdx: number; groupIdx: number }
  | { type: 'empty'; groupIdx: number };

function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const slots: Slot[] = [];
for (let i = 0; i < projects.length; i += 3) {
  const chunk = projects.slice(i, i + 3);
  const groupIdx = Math.floor(i / 3);
  const wideIdx  = Math.floor(Math.random() * chunk.length);

  const group: Slot[] = [
    ...chunk.map((p, j): Slot => ({
      type: 'card',
      project: p,
      projectIdx: i + j,
      groupIdx,
      isWide: j === wideIdx,
    } as any)),
    { type: 'empty', groupIdx },
  ];

  slots.push(...shuffle(group));
}
---

<!-- Fila de filtros por tag -->
<div style={`display:grid;grid-template-columns:repeat(5,1fr);`}>
  <div style={`outline:${BORDER};padding:1.25rem;grid-column:span 5;display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;`}>
    <TagFilter tags={allTags} />
  </div>
</div>

<!-- Grilla plana de 5 columnas -->
<div
  id="projects-grid"
  data-initial-visible={String(INITIAL_VISIBLE)}
  data-initial-visible-mobile="3"
  style="display:grid;grid-template-columns:repeat(5,1fr);"
>
  {slots.map(slot => {
    if (slot.type === 'empty') {
      // Celda vacía: oculta si el grupo está completamente plegado al inicio
      const groupStart  = slot.groupIdx * 3;
      const groupFolded = groupStart >= INITIAL_VISIBLE;
      return (
        <div
          class="grid-empty-slot"
          data-group={String(slot.groupIdx)}
          style={`outline:${BORDER};grid-column:span 1;${groupFolded ? 'display:none;' : ''}`}
        />
      );
    }

    // Tarjeta de proyecto
    const s = slot as any;
    const isFolded = s.projectIdx >= INITIAL_VISIBLE;
    return (
      <div
        class="project-card"
        data-tags={JSON.stringify(s.project.data.tags)}
        data-index={String(s.projectIdx)}
        data-group={String(s.groupIdx)}
        style={`outline:${BORDER};grid-column:span ${s.isWide ? 2 : 1};${isFolded ? 'display:none;' : ''}`}
      >
        <ProjectCard project={s.project} wide={s.isWide} />
      </div>
    );
  })}
</div>

<!-- Mensaje cuando ningún proyecto coincide con el filtro activo -->
<div id="no-results" class="hidden"
  style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.15em;color:rgba(26,26,26,0.4);padding:2rem 1.25rem;">
  No hay proyectos con este filtro.
</div>

<!-- Botón Ver más / Ver menos -->
<div id="show-more-section" style="display:none;">
  <div style={`display:grid;grid-template-columns:repeat(5,1fr);`}>
    <div style={`outline:${BORDER};padding:1.25rem;grid-column:span 5;display:flex;align-items:center;justify-content:center;`}>
      <button
        id="show-more-btn"
        style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.15em;padding:0.55rem 1.5rem;border:1px solid #1a1a1a;background:transparent;color:#1a1a1a;cursor:pointer;transition:all 0.15s;"
      >
        ↓ Ver más
      </button>
    </div>
  </div>
</div>

<!-- Franja decorativa inferior -->
<div style="display:grid;grid-template-columns:repeat(5,1fr);">
  <div style={`outline:${BORDER};padding:1rem 1.25rem;display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;grid-column:span 5;`}>
    <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.15em;padding:0.3rem 0.7rem;background:#c0fc04;color:#1a1a1a;">Design</span>
    <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.15em;padding:0.3rem 0.7rem;background:#ea027e;color:#fff;">Fabrication</span>
    <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.15em;padding:0.3rem 0.7rem;background:#3601fb;color:#fff;">Unreal</span>
    <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.15em;padding:0.3rem 0.7rem;background:#1a1a1a;color:#fff;">Robotics</span>
  </div>
</div>

<script>
  import { initTagFilter } from '../scripts/tag-filter';

  function initAll() {
    initTagFilter();

    // Scroll reveal escalonado al entrar al viewport
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const card = entry.target as HTMLElement;
          const siblings = Array.from(card.parentElement?.children ?? []);
          const idx = siblings.indexOf(card);
          card.style.transitionDelay = `${(idx % 5) * 60}ms`;
          card.classList.add('revealed');
          observer.unobserve(card);
        }
      });
    }, { threshold: 0.08 });

    document.querySelectorAll('.project-card').forEach(card => observer.observe(card));

    const btn = document.getElementById('show-more-btn');
    if (btn) {
      btn.addEventListener('mouseenter', () => { btn.style.background = '#1a1a1a'; btn.style.color = '#f8f7f5'; });
      btn.addEventListener('mouseleave', () => { btn.style.background = 'transparent'; btn.style.color = '#1a1a1a'; });
    }
  }

  document.addEventListener('astro:page-load', initAll);
</script>
