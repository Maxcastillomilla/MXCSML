---
// ─────────────────────────────────────────────────────────────────────────────
// HERO
// Sección de portada principal. Ocupa toda la pantalla (100vh desktop,
// 55vh mobile). Contiene:
//   - Canvas de Three.js con glitch effect sobre la foto + geometría 3D flotante
//   - Texto superpuesto en la esquina inferior izquierda
//   - Degradado inferior para transición suave hacia la sección de proyectos
//
// ANIMACIÓN DEL TÍTULO:
//   Al cargar muestra "MAXIMILIANO CASTILLO MILLA" y elimina palabras al azar
//   con efecto glitch hasta quedar solo "MXCSML". Después de 15 segundos se
//   reconstruye y el ciclo se repite infinitamente.
//
//   IMPORTANTE — layout fijo:
//   Las palabras usan visibility:hidden (no display:none) para que el h1
//   NO cambie de tamaño y el texto de abajo no se mueva. MXCSML es
//   position:absolute para superponerse sin afectar el flujo del documento.
//
// La foto que aparece en el hero es: public/images/perfil.png
// ─────────────────────────────────────────────────────────────────────────────
import ThreeScene from './ThreeScene.astro';
const BASE = import.meta.env.BASE_URL;
---
<section
  id="hero"
  class="relative h-[85vh] md:h-screen w-full overflow-hidden bg-[#1a1a1a] flex items-end"
  aria-label="Hero"
>
  <!-- Canvas Three.js: glitch sobre la foto + icosaedro 3D wireframe -->
  <ThreeScene />

  <!-- Texto superpuesto: disciplinas + nombre + descripción + CTA -->
  <div class="relative z-10 px-8 md:px-16 pb-20 max-w-4xl">
    <p class="font-mono text-xs uppercase tracking-widest text-white/40 mb-5">
      Computational Design · Digital Fabrication · Architectural Computing
    </p>

    <!--
      Título animado — estructura de layout fijo:
      • position:relative en el h1 ancla a MXCSML (absolute)
      • Las tres palabras siempre ocupan espacio (visibility:hidden, no display:none)
        → el h1 nunca cambia de altura → el texto de abajo no se desplaza
      • MXCSML se superpone con position:absolute top:0 left:0
        → no suma altura al h1

      Tamaños de fuente:
        Mobile:  text-[2.6rem] (≈70% del texto-6xl=3.75rem por defecto)
        Desktop: text-8xl (6rem) — sin cambios
    -->
    <h1
      id="hero-title"
      class="text-[2.6rem] md:text-8xl font-light text-white leading-none mb-8"
      style="position:relative;"
    >
      <!-- Palabras reales: siempre en el flujo, solo cambia visibility -->
      <span class="hero-word block" data-original="MAXIMILIANO">MAXIMILIANO</span>
      <span class="hero-word block" data-original="CASTILLO">CASTILLO</span>
      <span class="hero-word block" data-original="MILLA">MILLA</span>

      <!--
        Estado condensado: position:absolute para no mover el layout.
        Aparece encima de donde estaban las palabras (top:0 = primera línea).
        display:none inicial evita un flash de MXCSML antes que el JS arranque.
      -->
      <span
        id="hero-short"
        style="position:absolute;top:0;left:0;opacity:0;transition:opacity 0.4s ease;display:none;"
      >MXCSML</span>
    </h1>

    <p class="text-base text-white/60 max-w-sm font-light leading-relaxed mb-10">
      Researcher and educator working with parametric systems,
      fabrication workflows, and computational geometry
      in the built environment.
    </p>

    <!-- Flecha hacia proyectos -->
    <a
      href={`${BASE}#projects`}
      class="font-mono text-xs uppercase tracking-widest text-white/40 hover:text-white transition-colors"
    >
      View Work ↓
    </a>
  </div>

  <!-- Degradado inferior: difumina el hero hacia el fondo paper de proyectos -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#1a1a1a] to-transparent pointer-events-none"></div>
</section>

<script>
  // ─────────────────────────────────────────────────────────────────────────────
  // ANIMACIÓN DEL TÍTULO — ciclo infinito deconstruir / reconstruir
  //
  // Flujo:
  //   1. Mostrar MAXIMILIANO CASTILLO MILLA (pausa 1.2s)
  //   2. Eliminar cada palabra con glitch en orden aleatorio
  //      → visibility:hidden (no display:none) para no mover el layout
  //   3. Mostrar MXCSML (position:absolute, no afecta altura del h1)
  //   4. Esperar 15 segundos
  //   5. Ocultar MXCSML, reconstruir palabras con glitch en orden aleatorio
  //   6. Pausa 1.5s → volver al paso 2
  // ─────────────────────────────────────────────────────────────────────────────

  // Caracteres de ruido para el efecto glitch
  const GLITCH_CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ█▓▒░▄▀■□▪';

  // Bandera global para cancelar el loop al navegar entre páginas
  let animationActive = false;

  function randChar(): string {
    return GLITCH_CHARS[Math.floor(Math.random() * GLITCH_CHARS.length)];
  }

  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function sleep(ms: number): Promise<void> {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  // Glitch de salida: scramble chars → opacity 0 → visibility:hidden
  // USA visibility:hidden (no display:none) para que el elemento siga
  // ocupando espacio y el h1 no cambie de tamaño.
  function glitchOut(el: HTMLElement, duration = 350): Promise<void> {
    return new Promise(resolve => {
      const original = el.dataset.original ?? el.textContent ?? '';
      const t0 = performance.now();

      function frame(now: number) {
        if (!animationActive) { resolve(); return; }
        const p = Math.min((now - t0) / duration, 1);

        el.textContent = [...original].map(c =>
          c === ' ' ? ' ' : randChar()
        ).join('');
        el.style.opacity = (1 - p).toFixed(3);

        if (p < 1) {
          requestAnimationFrame(frame);
        } else {
          // visibility:hidden mantiene el espacio → no hay layout shift
          el.style.visibility = 'hidden';
          el.style.opacity    = '1';
          el.textContent      = original; // restaurar para uso futuro
          resolve();
        }
      }
      requestAnimationFrame(frame);
    });
  }

  // Glitch de entrada: visibility:visible → scramble → revelar letras de izq a der
  function glitchIn(el: HTMLElement, duration = 350): Promise<void> {
    return new Promise(resolve => {
      const original = el.dataset.original ?? el.textContent ?? '';
      el.style.visibility = 'visible';
      el.style.opacity    = '1';
      const t0 = performance.now();

      function frame(now: number) {
        if (!animationActive) { el.textContent = original; resolve(); return; }
        const p        = Math.min((now - t0) / duration, 1);
        const revealed = Math.floor(p * original.length);

        el.textContent = [...original].map((c, i) =>
          c === ' ' ? ' ' : (i < revealed ? c : randChar())
        ).join('');

        if (p < 1) {
          requestAnimationFrame(frame);
        } else {
          el.textContent = original;
          resolve();
        }
      }
      requestAnimationFrame(frame);
    });
  }

  // Loop principal — se llama recursivamente para el ciclo infinito
  async function runTitleAnimation() {
    const wordEls = Array.from(
      document.querySelectorAll<HTMLElement>('.hero-word')
    );
    const shortEl = document.getElementById('hero-short') as HTMLElement | null;
    if (!wordEls.length || !shortEl) return;

    // Restablecer estado inicial: palabras visibles, MXCSML oculto
    wordEls.forEach(el => {
      el.style.visibility = 'visible';
      el.style.opacity    = '1';
      el.textContent      = el.dataset.original ?? '';
    });
    shortEl.style.display = 'none';
    shortEl.style.opacity = '0';

    // Pausa inicial para que el usuario lea el nombre completo
    await sleep(15000);

    // ── FASE 1: Deconstruir ──────────────────────────────────────────────────
    for (const word of shuffle(wordEls)) {
      if (!animationActive) return;
      await glitchOut(word, 350);
      await sleep(250 + Math.random() * 350);
    }

    if (!animationActive) return;

    // ── FASE 2: Mostrar MXCSML ───────────────────────────────────────────────
    // display:block primero, luego opacity para que la transition funcione
    shortEl.style.display = 'block';
    await sleep(30);               // esperar un frame para que el navegador pinte
    shortEl.style.opacity = '1';

    // 15 segundos en estado condensado
    await sleep(4000);

    if (!animationActive) return;

    // ── FASE 3: Reconstruir ──────────────────────────────────────────────────
    shortEl.style.opacity = '0';
    await sleep(450);              // esperar la transition de opacity (400ms + margen)
    shortEl.style.display = 'none';

    for (const word of shuffle(wordEls)) {
      if (!animationActive) return;
      await glitchIn(word, 350);
      await sleep(200 + Math.random() * 250);
    }

    // Pausa con nombre completo visible antes del siguiente ciclo
    await sleep(1500);

    if (!animationActive) return;

    // ── Loop ─────────────────────────────────────────────────────────────────
    runTitleAnimation();
  }

  function init() {
    animationActive = true;
    runTitleAnimation();
  }

  // Cancelar el loop al navegar (View Transitions)
  document.addEventListener('astro:before-swap', () => {
    animationActive = false;
  });

  // Iniciar al cargar la página (y en cada navegación)
  document.addEventListener('astro:page-load', () => {
    if (document.querySelector('.hero-word')) {
      init();
    }
  });
</script>
