---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
const BORDER = '1px solid #c2c2c2';
---
<aside style="margin-top:6rem;">

  <!-- Section header row: 4 cols (2 cards × span 2 = 4) -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);">
    <div style={`outline:${BORDER};padding:1rem 1.25rem;display:flex;align-items:flex-end;`}>
      <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.15em;color:rgba(26,26,26,0.4);">(02)</span>
    </div>
    <div style={`outline:${BORDER};grid-column:span 2;padding:1rem 1.25rem;display:flex;align-items:flex-end;background:#ea027e;`}>
      <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.15em;color:#f8f7f5;">Related Work</span>
    </div>
    <div style={`outline:${BORDER};background:#3601fb;`}></div>
  </div>

  <!-- 2 cards side by side, each spanning 2 of 4 cols -->
  <div class="related-cards-row" style="display:grid;grid-template-columns:repeat(4,1fr);">
    {projects.map(p => (
      <a
        href={`${import.meta.env.BASE_URL}projects/${p.id}`}
        class="group related-card"
        style={`outline:${BORDER};text-decoration:none;color:inherit;display:flex;flex-direction:column;grid-column:span 2;`}
      >
        <div style="overflow:hidden;aspect-ratio:4/3;">
          <Image
            src={p.data.cover}
            alt={p.data.title}
            width={600}
            height={450}
            style="width:100%;height:100%;object-fit:cover;filter:grayscale(100%);transition:filter 0.5s;"
            class="group-hover:grayscale-0"
          />
        </div>
        <div style="padding:0.75rem 1rem;">
          <div style="display:flex;flex-wrap:wrap;gap:0.3rem;margin-bottom:0.4rem;">
            {p.data.tags.map(tag => (
              <span style="font-family:'JetBrains Mono',monospace;font-size:0.55rem;text-transform:uppercase;letter-spacing:0.1em;color:rgba(26,26,26,0.4);">{tag}</span>
            ))}
          </div>
          <h3 style="font-size:0.85rem;font-weight:300;margin:0;transition:opacity 0.2s;" class="group-hover:opacity-50">
            {p.data.title}
          </h3>
        </div>
      </a>
    ))}
  </div>

  <!-- Accent strip -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);">
    <div style={`outline:${BORDER};background:#c0fc04;height:0.75rem;grid-column:span 2;`}></div>
    <div style={`outline:${BORDER};height:0.75rem;grid-column:span 2;`}></div>
  </div>

</aside>

<style>
  @media (max-width: 767px) {
    .related-cards-row {
      grid-template-columns: 1fr !important;
    }
    .related-card {
      grid-column: 1 / -1 !important;
    }
  }
</style>
