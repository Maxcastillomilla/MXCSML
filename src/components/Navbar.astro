---
// ─────────────────────────────────────────────────────────────────────────────
// NAVBAR
// Barra de navegación fija en la parte superior de todas las páginas.
//
// Desktop: logo "MC" a la izquierda + links a la derecha.
//          Usa mix-blend-difference → el texto blanco se invierte automáticamente
//          contra fondos claros (aparece negro) y oscuros (aparece blanco).
//          Así funciona en el hero oscuro Y en la sección proyectos clara.
//
// Mobile:  Solo el logo visible. Aparece un botón ☰ (hamburguesa) en la
//          esquina superior derecha que abre un overlay de pantalla completa.
//
// El botón hamburguesa está FUERA del <header> para evitar heredar
// "pointer-events: none" del header y asegurar que siempre sea clickeable.
// ─────────────────────────────────────────────────────────────────────────────
// BASE_URL = '/MXCSML/' en producción (GitHub Pages), '/' en dev local
const BASE = import.meta.env.BASE_URL;
---

<!-- Header: solo visible en desktop para el logo + links -->
<header class="fixed top-0 left-0 right-0 z-50 pointer-events-none" style="mix-blend-mode:difference;">
  <nav class="flex items-center justify-between px-6 md:px-8 py-5 md:py-6 pointer-events-auto">
    <a href={BASE} class="font-mono text-sm text-white tracking-widest uppercase">MC</a>
    <!-- Links solo visibles en desktop (md = 768px+) -->
    <ul class="hidden md:flex gap-8">
      <li>
        <a href={`${BASE}#about`} class="font-mono text-xs uppercase tracking-widest text-white hover:opacity-60 transition-opacity">
          About
        </a>
      </li>
      <li>
        <a href={`${BASE}#projects`} class="font-mono text-xs uppercase tracking-widest text-white hover:opacity-60 transition-opacity">
          Projects
        </a>
      </li>
      <li>
        <a href={`${BASE}#contact`} class="font-mono text-xs uppercase tracking-widest text-white hover:opacity-60 transition-opacity">
          Contact
        </a>
      </li>
    </ul>
  </nav>
</header>

<!-- ── Botón hamburguesa (solo mobile) ───────────────────────────────────────
     Posición fija independiente del header.
     mix-blend-mode: difference → las barras blancas se invierten contra
     cualquier fondo, igual que el logo del desktop nav.
     El JS de abajo lo muestra/oculta según el ancho de pantalla.
─────────────────────────────────────────────────────────────────────────────── -->
<button
  id="menu-toggle"
  aria-label="Toggle menu"
  aria-expanded="false"
  style="display:none;position:fixed;top:1.1rem;right:1.25rem;z-index:9999;flex-direction:column;justify-content:center;gap:6px;width:2.5rem;height:2.5rem;background:none;border:none;cursor:pointer;mix-blend-mode:difference;padding:0.5rem;"
>
  <!-- Las 3 barras se animan a una X cuando el menú está abierto -->
  <span class="menu-bar" style="display:block;width:22px;height:2px;background:#ffffff;transition:transform 0.2s,opacity 0.2s;transform-origin:center;"></span>
  <span class="menu-bar" style="display:block;width:22px;height:2px;background:#ffffff;transition:transform 0.2s,opacity 0.2s;transform-origin:center;"></span>
  <span class="menu-bar" style="display:block;width:22px;height:2px;background:#ffffff;transition:transform 0.2s,opacity 0.2s;transform-origin:center;"></span>
</button>

<!-- ── Overlay del menú mobile ────────────────────────────────────────────────
     Cubre toda la pantalla cuando el menú está abierto.
     El JS alterna display entre 'none' y 'flex'.
─────────────────────────────────────────────────────────────────────────────── -->
<div
  id="mobile-menu"
  style="display:none;position:fixed;inset:0;z-index:9000;background:#1a1a1a;flex-direction:column;align-items:center;justify-content:center;gap:3rem;"
>
  <a href={`${BASE}#about`} class="mobile-menu-link"
    style="font-family:'JetBrains Mono',monospace;font-size:1.5rem;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.7);text-decoration:none;">
    About
  </a>
  <a href={`${BASE}#projects`} class="mobile-menu-link"
    style="font-family:'JetBrains Mono',monospace;font-size:1.5rem;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.7);text-decoration:none;">
    Projects
  </a>
  <a href={`${BASE}#contact`} class="mobile-menu-link"
    style="font-family:'JetBrains Mono',monospace;font-size:1.5rem;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.7);text-decoration:none;">
    Contact
  </a>
</div>

<script>
  function initMenu() {
    const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
    const menu   = document.getElementById('mobile-menu') as HTMLElement | null;
    if (!toggle || !menu) return;

    const bars = Array.from(toggle.querySelectorAll<HTMLElement>('.menu-bar'));

    // Mostrar el botón solo en mobile (< 768px)
    const mq = window.matchMedia('(max-width: 767px)');
    const syncVisibility = (e: MediaQueryList | MediaQueryListEvent) => {
      toggle.style.display = e.matches ? 'flex' : 'none';
    };
    syncVisibility(mq);
    mq.addEventListener('change', syncVisibility);

    let open = false;

    function setOpen(val: boolean) {
      open = val;
      toggle.setAttribute('aria-expanded', String(open));
      menu.style.display = open ? 'flex' : 'none';

      if (open) {
        // Animar barras → X
        bars[0].style.transform = 'translateY(8px) rotate(45deg)';
        bars[1].style.opacity   = '0';
        bars[2].style.transform = 'translateY(-8px) rotate(-45deg)';
      } else {
        // Restaurar barras ☰
        bars[0].style.transform = '';
        bars[1].style.opacity   = '';
        bars[2].style.transform = '';
      }
    }

    toggle.addEventListener('click', () => setOpen(!open));

    // Cerrar menú al hacer click en un link
    menu.querySelectorAll('.mobile-menu-link').forEach(a => {
      a.addEventListener('click', () => setOpen(false));
    });
  }

  // Se reinicializa en cada navegación (necesario para Astro View Transitions)
  document.addEventListener('astro:page-load', initMenu);
</script>
